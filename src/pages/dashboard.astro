<script define:vars={{ scriptData }}>
  const {
    holidayTarget,
  } = scriptData;

  // ===== 北京时间时钟 =====
  function updateClock() {
    const now = new Date();
    const h = String(now.getHours()).padStart(2, '0');
    const m = String(now.getMinutes()).padStart(2, '0');
    const s = String(now.getSeconds()).padStart(2, '0');
    document.getElementById('hours').textContent = h;
    document.getElementById('minutes').textContent = m;
    document.getElementById('seconds').textContent = s;
    document.getElementById('dateDisplay').textContent = now.toLocaleDateString('zh-CN', {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
      weekday: 'long',
    });
  }

  // ===== 计算年剩余 =====
  function updateYearRemain() {
    const now = new Date();
    const yearStart = new Date(now.getFullYear(), 0, 1);
    const yearEnd = new Date(now.getFullYear() + 1, 0, 1);
    const total = yearEnd.getTime() - yearStart.getTime();
    const elapsed = now.getTime() - yearStart.getTime();
    const progress = (elapsed / total) * 100;
    const diff = yearEnd.getTime() - now.getTime();
    
    if (diff <= 0) {
      document.getElementById('yearRemain').textContent = '已结束';
      document.getElementById('yearProgressFill').style.width = '100%';
      document.getElementById('yearPercent').textContent = '100%';
      return;
    }
    
    const days = Math.floor(diff / (1000 * 60 * 60 * 24));
    const hours = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
    const mins = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
    const secs = Math.floor((diff % (1000 * 60)) / 1000);
    
    document.getElementById('yearRemain').textContent = 
      days + '天' + hours + '时' + mins + '分' + secs + '秒';
    
    const progressRounded = Math.round(progress * 10) / 10;
    document.getElementById('yearProgressFill').style.width = progress + '%';
    document.getElementById('yearPercent').textContent = progressRounded + '%';
  }

  // ===== 计算月剩余 =====
  function updateMonthRemain() {
    const now = new Date();
    const monthStart = new Date(now.getFullYear(), now.getMonth(), 1);
    const monthEnd = new Date(now.getFullYear(), now.getMonth() + 1, 1);
    const total = monthEnd.getTime() - monthStart.getTime();
    const elapsed = now.getTime() - monthStart.getTime();
    const progress = (elapsed / total) * 100;
    const diff = monthEnd.getTime() - now.getTime();
    
    if (diff <= 0) {
      document.getElementById('monthRemain').textContent = '已结束';
      document.getElementById('monthProgressFill').style.width = '100%';
      document.getElementById('monthPercent').textContent = '100%';
      return;
    }
    
    const days = Math.floor(diff / (1000 * 60 * 60 * 24));
    const hours = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
    const mins = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
    const secs = Math.floor((diff % (1000 * 60)) / 1000);
    
    document.getElementById('monthRemain').textContent = 
      days + '天' + hours + '时' + mins + '分' + secs + '秒';
    
    const progressRounded = Math.round(progress * 10) / 10;
    document.getElementById('monthProgressFill').style.width = progress + '%';
    document.getElementById('monthPercent').textContent = progressRounded + '%';
  }

  // ===== 计算周剩余 =====
  function updateWeekRemain() {
    const now = new Date();
    const w = now.getDay() || 7;
    const daySec = now.getHours() * 3600 + now.getMinutes() * 60 + now.getSeconds();
    const totalSec = (7 - w) * 86400 + (86400 - daySec);
    
    if (totalSec <= 0) {
      document.getElementById('weekRemain').textContent = '已结束';
      document.getElementById('weekProgressFill').style.width = '100%';
      document.getElementById('weekPercent').textContent = '100%';
      return;
    }
    
    const days = Math.floor(totalSec / 86400);
    const hours = Math.floor((totalSec % 86400) / 3600);
    const mins = Math.floor((totalSec % 3600) / 60);
    const secs = Math.floor(totalSec % 60);
    
    document.getElementById('weekRemain').textContent = 
      days + '天' + hours + '时' + mins + '分' + secs + '秒';
    
    const weekElapsed = (w - 1) * 86400 + daySec;
    const weekTotal = 7 * 86400;
    const progress = (weekElapsed / weekTotal) * 100;
    const progressRounded = Math.round(progress * 10) / 10;
    document.getElementById('weekProgressFill').style.width = progress + '%';
    document.getElementById('weekPercent').textContent = progressRounded + '%';
  }

  // ===== 节日倒计时 =====
  function updateHoliday() {
    if (holidayTarget !== null) {
      const diff = holidayTarget - Date.now();
      if (diff > 0) {
        const days = Math.floor(diff / (1000 * 60 * 60 * 24));
        document.getElementById('holidayRemain').textContent = days;
      } else {
        document.getElementById('holidayRemain').textContent = '0';
      }
    }
  }

  // ===== 启动所有定时器 =====
  updateClock();
  setInterval(updateClock, 1000);
  
  updateYearRemain();
  setInterval(updateYearRemain, 1000);
  
  updateMonthRemain();
  setInterval(updateMonthRemain, 1000);
  
  updateWeekRemain();
  setInterval(updateWeekRemain, 1000);
  
  updateHoliday();
  setInterval(updateHoliday, 60000);
</script>