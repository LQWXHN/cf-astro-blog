---
import { env } from "cloudflare:workers";
import Base from "@/layouts/Base.astro";

// ===== 配置区 =====
const UAPI_KEY = "uapi-nwvozms5PJdxLNRw3TJUSQ4nmP_54yHVi9XzIrXX";

// ===== 通过 IP 查询获取精确地理位置（精确到区县） =====
async function fetchLocationByIP() {
  try {
    const controller = new AbortController();
    const timeoutId = setTimeout(() => controller.abort(), 5000);
    const res = await fetch(`https://ip9.com.cn/get`, {
      signal: controller.signal,
    });
    clearTimeout(timeoutId);
    if (!res.ok) throw new Error(`HTTP ${res.status}`);
    const data = await res.json();
    if (data.ret === 200 && data.data) {
      const { city, area } = data.data;
      return area && area !== "未知" ? area : city || "北京";
    }
    return "北京";
  } catch {
    const city = Astro.request.headers.get("cf-city") || "";
    const region = Astro.request.headers.get("cf-region") || "";
    return city || region || "北京";
  }
}

// ===== 获取实时天气 =====
async function fetchWeather(location: string) {
  try {
    const controller = new AbortController();
    const timeoutId = setTimeout(() => controller.abort(), 8000);
    const res = await fetch(
      `https://uapis.cn/api/v1/misc/weather?city=${encodeURIComponent(location)}&extended=true&forecast=true&lang=zh`,
      {
        headers: { Authorization: `Bearer ${UAPI_KEY}` },
        signal: controller.signal,
      }
    );
    clearTimeout(timeoutId);
    if (!res.ok) throw new Error(`HTTP ${res.status}`);
    return await res.json();
  } catch {
    return null;
  }
}

// ===== 获取历史天气 =====
async function fetchWeatherHistory(location: string) {
  try {
    const controller = new AbortController();
    const timeoutId = setTimeout(() => controller.abort(), 8000);
    const res = await fetch(
      `https://uapis.cn/api/v1/misc/weather/history?city=${encodeURIComponent(location)}&days=7&lang=zh`,
      {
        headers: { Authorization: `Bearer ${UAPI_KEY}` },
        signal: controller.signal,
      }
    );
    clearTimeout(timeoutId);
    if (!res.ok) throw new Error(`HTTP ${res.status}`);
    return await res.json();
  } catch {
    return null;
  }
}

// ===== 获取热榜 =====
async function fetchHotboard() {
  try {
    const controller = new AbortController();
    const timeoutId = setTimeout(() => controller.abort(), 8000);
    const res = await fetch(`https://uapis.cn/api/v1/misc/hotboard?type=weibo`, {
      headers: { Authorization: `Bearer ${UAPI_KEY}` },
      signal: controller.signal,
    });
    clearTimeout(timeoutId);
    if (!res.ok) throw new Error(`HTTP ${res.status}`);
    return await res.json();
  } catch {
    return null;
  }
}

// ===== 获取节假日 =====
async function fetchHoliday() {
  try {
    const now = new Date();
    const today = now.toISOString().split("T")[0];
    const controller = new AbortController();
    const timeoutId = setTimeout(() => controller.abort(), 8000);
    const res = await fetch(
      `https://uapis.cn/api/v1/misc/holiday-calendar?date=${today}&include_nearby=true&nearby_limit=10&exclude_past=true&timezone=Asia/Shanghai`,
      {
        headers: { Authorization: `Bearer ${UAPI_KEY}` },
        signal: controller.signal,
      }
    );
    clearTimeout(timeoutId);
    if (!res.ok) throw new Error(`HTTP ${res.status}`);
    return await res.json();
  } catch {
    return null;
  }
}

// ===== 获取一言 =====
async function fetchSaying() {
  try {
    const controller = new AbortController();
    const timeoutId = setTimeout(() => controller.abort(), 5000);
    const res = await fetch(`https://uapis.cn/api/v1/saying`, {
      signal: controller.signal,
    });
    clearTimeout(timeoutId);
    if (!res.ok) throw new Error(`HTTP ${res.status}`);
    return await res.json();
  } catch {
    return null;
  }
}

// ===== 获取必应壁纸 =====
async function fetchBingWallpaper() {
  try {
    const controller = new AbortController();
    const timeoutId = setTimeout(() => controller.abort(), 8000);
    const res = await fetch(
      `https://uapis.cn/api/v1/image/bing-daily?format=json&resolution=4k`,
      {
        headers: { Authorization: `Bearer ${UAPI_KEY}` },
        signal: controller.signal,
      }
    );
    clearTimeout(timeoutId);
    if (!res.ok) throw new Error(`HTTP ${res.status}`);
    return await res.json();
  } catch {
    return null;
  }
}

// ===== 计算日期进度（返回起始和结束时间戳） =====
function getDateProgress() {
  const now = new Date();
  const yearStart = new Date(now.getFullYear(), 0, 1);
  const yearEnd = new Date(now.getFullYear() + 1, 0, 1);
  const yearTotal = yearEnd.getTime() - yearStart.getTime();
  const yearElapsed = now.getTime() - yearStart.getTime();
  const yearProgress = (yearElapsed / yearTotal) * 100;

  const monthStart = new Date(now.getFullYear(), now.getMonth(), 1);
  const monthEnd = new Date(now.getFullYear(), now.getMonth() + 1, 1);
  const monthTotal = monthEnd.getTime() - monthStart.getTime();
  const monthElapsed = now.getTime() - monthStart.getTime();
  const monthProgress = (monthElapsed / monthTotal) * 100;

  const dayOfWeek = now.getDay() || 7;
  const weekStart = new Date(now);
  weekStart.setDate(now.getDate() - (dayOfWeek - 1));
  weekStart.setHours(0, 0, 0, 0);
  const weekEnd = new Date(weekStart);
  weekEnd.setDate(weekStart.getDate() + 7);
  const weekTotal = weekEnd.getTime() - weekStart.getTime();
  const weekElapsed = now.getTime() - weekStart.getTime();
  const weekProgress = (weekElapsed / weekTotal) * 100;

  const daysInYear = Math.ceil((yearEnd.getTime() - yearStart.getTime()) / (1000 * 60 * 60 * 24));
  const daysPassed = Math.floor((now.getTime() - yearStart.getTime()) / (1000 * 60 * 60 * 24));
  const daysInMonth = new Date(now.getFullYear(), now.getMonth() + 1, 0).getDate();

  return {
    yearProgress: Math.round(yearProgress * 10) / 10,
    monthProgress: Math.round(monthProgress * 10) / 10,
    weekProgress: Math.round(weekProgress * 10) / 10,
    yearRemain: daysInYear - daysPassed,
    monthRemain: daysInMonth - now.getDate(),
    weekRemain: 7 - dayOfWeek,
    yearStart: yearStart.getTime(),
    yearEnd: yearEnd.getTime(),
    monthStart: monthStart.getTime(),
    monthEnd: monthEnd.getTime(),
    weekStart: weekStart.getTime(),
    weekEnd: weekEnd.getTime(),
  };
}

// ===== 主流程 =====
const location = await fetchLocationByIP();
const [weather, weatherHistory, hotboard, holiday, saying, bing] = await Promise.all([
  fetchWeather(location),
  fetchWeatherHistory(location),
  fetchHotboard(),
  fetchHoliday(),
  fetchSaying(),
  fetchBingWallpaper(),
]);

const progress = getDateProgress();
const nextHoliday = holiday?.nearby?.[0];
const holidayTarget = nextHoliday ? new Date(nextHoliday.date).getTime() : null;

// ===== 准备传递给客户端的数据 =====
const scriptData = {
  yearStart: progress.yearStart,
  yearEnd: progress.yearEnd,
  monthStart: progress.monthStart,
  monthEnd: progress.monthEnd,
  weekStart: progress.weekStart,
  weekEnd: progress.weekEnd,
  holidayTarget: holidayTarget,
};
---

<Base title="仪表盘" description="信息聚合中心">
  <div class="dashboard-grid">
    <!-- 1. 时间卡片 -->
    <div class="dashboard-card glass-panel">
      <div class="card-header">
        <span class="card-icon">🕐</span>
        <span class="card-title">北京时间</span>
      </div>
      <div class="time-display">
        <div class="time-seconds" id="timeDisplay">
          <span id="hours">00</span>:<span id="minutes">00</span>:<span id="seconds">00</span>
        </div>
        <div class="time-date" id="dateDisplay"></div>
      </div>
    </div>

    <!-- 2. 今日天气 -->
    <div class="dashboard-card glass-panel">
      <div class="card-header">
        <span class="card-icon">🌤️</span>
        <span class="card-title">今日天气 · {location}</span>
      </div>
      {weather ? (
        <div class="weather-content">
          <div class="weather-main">
            <span class="weather-temp">{weather.temp}°C</span>
            <span class="weather-desc">{weather.weather}</span>
          </div>
          <div class="weather-details">
            <span>🌡️ 体感 {weather.feels_like}°C</span>
            <span>💧 湿度 {weather.humidity}%</span>
            <span>🌬️ 风速 {weather.wind_speed}km/h</span>
          </div>
        </div>
      ) : (
        <p class="empty-state">加载中...</p>
      )}
    </div>

    <!-- 3. 历史天气 -->
    <div class="dashboard-card glass-panel">
      <div class="card-header">
        <span class="card-icon">📊</span>
        <span class="card-title">近7天天气 · {location}</span>
      </div>
      {weatherHistory?.days && weatherHistory.days.length > 0 ? (
        <div class="history-chart">
          {weatherHistory.days.map((d: any) => (
            <div
              class="history-bar"
              title={`${d.date}: ${d.weather} ${d.temp_max}°C`}
            >
              <div
                class="bar"
                style="height: ${(d.temp_max / 40) * 100}%; background: ${d.rained ? '#4a9eff' : '#ffb74d'};"
              ></div>
              <span class="bar-label">${d.date.slice(5)}</span>
            </div>
          ))}
        </div>
      ) : (
        <p class="empty-state">加载中...</p>
      )}
    </div>

    <!-- 4. 热榜 -->
    <div class="dashboard-card glass-panel" style="grid-column: span 2;">
      <div class="card-header">
        <span class="card-icon">🔥</span>
        <span class="card-title">微博热榜</span>
      </div>
      {hotboard?.list ? (
        <ol class="hot-list">
          {hotboard.list.slice(0, 10).map((item: any, i: number) => (
            <li key={i}>
              <a href={item.url} target="_blank" rel="noopener">
                <span class="hot-index">{i + 1}</span>
                <span class="hot-title">{item.title}</span>
                <span class="hot-value">{item.hot_value}</span>
              </a>
            </li>
          ))}
        </ol>
      ) : (
        <p class="empty-state">加载中...</p>
      )}
    </div>

    <!-- 5. 日历 + 进度 -->
    <div class="dashboard-card glass-panel">
      <div class="card-header">
        <span class="card-icon">📅</span>
        <span class="card-title">日历 & 进度</span>
      </div>
      <div class="calendar-content">
        <!-- 本年剩余 -->
        <div class="progress-item">
          <span id="yearLabel">本年剩余 <strong id="yearRemain">{progress.yearRemain}</strong> 天</span>
          <div class="progress-bar">
            <div class="progress-fill" id="yearProgressFill" style="width: {progress.yearProgress}%;"></div>
          </div>
          <span class="progress-label" id="yearPercent">{progress.yearProgress}%</span>
        </div>
        <!-- 本月剩余 -->
        <div class="progress-item">
          <span id="monthLabel">本月剩余 <strong id="monthRemain">{progress.monthRemain}</strong> 天</span>
          <div class="progress-bar">
            <div class="progress-fill" id="monthProgressFill" style="width: {progress.monthProgress}%;"></div>
          </div>
          <span class="progress-label" id="monthPercent">{progress.monthProgress}%</span>
        </div>
        <!-- 本周剩余 -->
        <div class="progress-item">
          <span id="weekLabel">本周剩余 <strong id="weekRemain">{progress.weekRemain}</strong> 天</span>
          <div class="progress-bar">
            <div class="progress-fill" id="weekProgressFill" style="width: {progress.weekProgress}%;"></div>
          </div>
          <span class="progress-label" id="weekPercent">{progress.weekProgress}%</span>
        </div>
        <!-- 距离下一个节日 -->
        {nextHoliday && (
          <div class="next-holiday" id="holidayInfo">
            🎉 距离 <strong>{nextHoliday.name}</strong> 还有{' '}
            <strong id="holidayRemain">{nextHoliday.days_until}</strong> 天
          </div>
        )}
      </div>
    </div>

    <!-- 6. 一言 -->
    <div class="dashboard-card glass-panel">
      <div class="card-header">
        <span class="card-icon">💬</span>
        <span class="card-title">今日一言</span>
      </div>
      <p class="saying-text">“{saying?.text || '加载中...'}”</p>
    </div>

    <!-- 7. 必应壁纸 -->
    <div class="dashboard-card glass-panel" style="grid-column: span 2;">
      <div class="card-header">
        <span class="card-icon">🖼️</span>
        <span class="card-title">今日壁纸</span>
      </div>
      {bing?.image_url ? (
        <div class="bing-wallpaper">
          <img src={bing.image_url} alt={bing.title || 'Bing Wallpaper'} />
          <div class="bing-caption">{bing.title} · {bing.copyright}</div>
        </div>
      ) : (
        <p class="empty-state">加载中...</p>
      )}
    </div>
  </div>
</Base>

<style>
  /* 样式保持不变 */
  .dashboard-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.2rem;
    padding: 1.5rem 0;
  }

  .dashboard-card {
    --glass-panel-opacity: calc(var(--hero-card-opacity, 14) / 100);
    --glass-panel-blur: var(--hero-card-blur, 18px);
    padding: 1.2rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .card-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--color-text-secondary);
    border-bottom: 1px solid var(--color-border);
    padding-bottom: 0.4rem;
  }

  .card-icon { font-size: 1.2rem; }

  .time-display { text-align: center; padding: 0.5rem 0; }
  .time-seconds { font-size: 2.8rem; font-weight: 700; font-family: var(--font-mono); letter-spacing: 0.04em; }
  .time-date { font-size: 1rem; color: var(--color-text-muted); margin-top: 0.2rem; }

  .weather-content { display: flex; flex-direction: column; gap: 0.4rem; }
  .weather-main { display: flex; align-items: baseline; gap: 0.8rem; }
  .weather-temp { font-size: 2.2rem; font-weight: 700; }
  .weather-desc { font-size: 1rem; color: var(--color-text-secondary); }
  .weather-details { display: flex; flex-wrap: wrap; gap: 0.5rem 1rem; font-size: 0.85rem; color: var(--color-text-muted); }

  .history-chart { display: flex; align-items: flex-end; gap: 0.4rem; height: 80px; padding-top: 0.5rem; }
  .history-bar { display: flex; flex-direction: column; align-items: center; flex: 1; height: 100%; }
  .history-bar .bar { width: 100%; min-height: 4px; border-radius: 4px 4px 0 0; transition: height 0.3s; }
  .history-bar .bar-label { font-size: 0.6rem; color: var(--color-text-muted); margin-top: 0.2rem; }

  .hot-list { list-style: none; padding: 0; margin: 0; }
  .hot-list li { padding: 0.35rem 0; border-bottom: 1px solid var(--color-border); }
  .hot-list li:last-child { border-bottom: none; }
  .hot-list a { display: flex; align-items: center; gap: 0.6rem; text-decoration: none; color: var(--color-text); }
  .hot-list a:hover { color: var(--color-accent); }
  .hot-index { font-weight: 700; color: var(--color-text-muted); min-width: 1.6rem; font-size: 0.85rem; }
  .hot-list li:nth-child(1) .hot-index { color: #f44336; }
  .hot-list li:nth-child(2) .hot-index { color: #ff9800; }
  .hot-list li:nth-child(3) .hot-index { color: #ffc107; }
  .hot-title { flex: 1; font-size: 0.9rem; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .hot-value { font-size: 0.75rem; color: var(--color-text-muted); }

  .calendar-content { display: flex; flex-direction: column; gap: 0.6rem; }
  .progress-item { display: grid; grid-template-columns: 1fr auto; gap: 0.2rem 0.6rem; align-items: center; font-size: 0.9rem; }
  .progress-item span:first-child { color: var(--color-text-secondary); }
  .progress-item strong { color: var(--color-text); }
  .progress-bar { grid-column: 1 / 2; height: 6px; background: var(--color-bg-tertiary); border-radius: 999px; overflow: hidden; }
  .progress-fill { height: 100%; border-radius: 999px; background: var(--color-accent); transition: width 0.3s ease; }
  .progress-label { font-size: 0.75rem; color: var(--color-text-muted); }
  .next-holiday { margin-top: 0.4rem; padding: 0.5rem 0.8rem; background: var(--color-accent-soft); border-radius: var(--radius-inner); text-align: center; font-size: 0.95rem; }

  .saying-text { font-size: 1.1rem; font-style: italic; color: var(--color-text-secondary); padding: 0.5rem 0; line-height: 1.6; text-align: center; }

  .bing-wallpaper { position: relative; border-radius: var(--radius-inner); overflow: hidden; }
  .bing-wallpaper img { width: 100%; height: 180px; object-fit: cover; display: block; }
  .bing-caption { position: absolute; bottom: 0; left: 0; right: 0; padding: 0.5rem 1rem; background: linear-gradient(transparent, rgba(0,0,0,0.6)); color: #fff; font-size: 0.8rem; }

  @media (max-width: 1024px) {
    .dashboard-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 640px) {
    .dashboard-grid { grid-template-columns: 1fr; }
  }
</style>

<script define:vars={{ scriptData }}>
  const {
    yearStart, yearEnd,
    monthStart, monthEnd,
    weekStart, weekEnd,
    holidayTarget,
  } = scriptData;

  // 实时时钟（每秒）
  function updateClock() {
    const now = new Date();
    const h = String(now.getHours()).padStart(2, '0');
    const m = String(now.getMinutes()).padStart(2, '0');
    const s = String(now.getSeconds()).padStart(2, '0');
    document.getElementById('hours').textContent = h;
    document.getElementById('minutes').textContent = m;
    document.getElementById('seconds').textContent = s;
    document.getElementById('dateDisplay').textContent = now.toLocaleDateString('zh-CN', {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
      weekday: 'long',
    });
  }

  // 更新单个进度项
  function updateItem(remainId, progressId, percentId, start, end, now, updateProgress) {
    const total = end - start;
    const elapsed = now - start;
    let progressPercent = 0;
    let remainText = '';

    if (elapsed <= 0) {
      progressPercent = 0;
      remainText = '0天0时0分0秒';
    } else if (elapsed >= total) {
      progressPercent = 100;
      remainText = '已结束';
    } else {
      progressPercent = (elapsed / total) * 100;
      const diff = end - now;
      const days = Math.floor(diff / (1000 * 60 * 60 * 24));
      const hours = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
      const minutes = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
      const seconds = Math.floor((diff % (1000 * 60)) / 1000);
      remainText = `${days}天${hours}时${minutes}分${seconds}秒`;
    }

    document.getElementById(remainId).textContent = remainText;

    if (updateProgress) {
      const progressRounded = Math.round(progressPercent * 10) / 10;
      document.getElementById(progressId).style.width = progressPercent + '%';
      document.getElementById(percentId).textContent = progressRounded + '%';
    }
  }

  // 更新剩余时间（每秒，不更新进度条）
  function updateCountdown() {
    const now = Date.now();
    updateItem('yearRemain', 'yearProgressFill', 'yearPercent', yearStart, yearEnd, now, false);
    updateItem('monthRemain', 'monthProgressFill', 'monthPercent', monthStart, monthEnd, now, false);
    updateItem('weekRemain', 'weekProgressFill', 'weekPercent', weekStart, weekEnd, now, false);

    if (holidayTarget !== null) {
      const diff = holidayTarget - now;
      if (diff > 0) {
        const days = Math.floor(diff / (1000 * 60 * 60 * 24));
        document.getElementById('holidayRemain').textContent = days;
      } else {
        document.getElementById('holidayRemain').textContent = '0';
      }
    }
  }

  // 更新进度条（每小时调用，更新宽度和百分比）
  function updateProgressBars() {
    const now = Date.now();
    updateItem('yearRemain', 'yearProgressFill', 'yearPercent', yearStart, yearEnd, now, true);
    updateItem('monthRemain', 'monthProgressFill', 'monthPercent', monthStart, monthEnd, now, true);
    updateItem('weekRemain', 'weekProgressFill', 'weekPercent', weekStart, weekEnd, now, true);
  }

  // 初始化
  updateClock();
  setInterval(updateClock, 1000);

  updateCountdown();
  setInterval(updateCountdown, 1000);

  // 进度条每小时更新一次
  let lastHour = new Date().getHours();
  setInterval(() => {
    const now = new Date();
    const currentHour = now.getHours();
    if (currentHour !== lastHour) {
      lastHour = currentHour;
      updateProgressBars();
    }
  }, 1000);
</script>