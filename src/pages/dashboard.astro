<script define:vars={{ scriptData }}>
  const {
    yearStart, yearEnd,
    monthStart, monthEnd,
    holidayTarget,
  } = scriptData;

  // ===== 北京时间时钟 =====
  function updateClock() {
    const now = new Date();
    const h = String(now.getHours()).padStart(2, '0');
    const m = String(now.getMinutes()).padStart(2, '0');
    const s = String(now.getSeconds()).padStart(2, '0');
    document.getElementById('hours').textContent = h;
    document.getElementById('minutes').textContent = m;
    document.getElementById('seconds').textContent = s;
    document.getElementById('dateDisplay').textContent = now.toLocaleDateString('zh-CN', {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
      weekday: 'long',
    });
  }

  // ===== 更新进度（年/月/节日） =====
  function updateItem(remainId, progressId, percentId, start, end, now, updateProgress) {
    const total = end - start;
    const elapsed = now - start;
    let progressPercent = 0;
    let remainText = '';
    if (elapsed <= 0) {
      progressPercent = 0;
      remainText = '0天0时0分0秒';
    } else if (elapsed >= total) {
      progressPercent = 100;
      remainText = '已结束';
    } else {
      progressPercent = (elapsed / total) * 100;
      const diff = end - now;
      const days = Math.floor(diff / (1000 * 60 * 60 * 24));
      const hours = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
      const minutes = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
      const seconds = Math.floor((diff % (1000 * 60)) / 1000);
      if (days > 0) {
        remainText = days + '天' + hours + '时' + minutes + '分' + seconds + '秒';
      } else {
        let parts = [];
        if (hours > 0) parts.push(hours + '时');
        if (minutes > 0) parts.push(minutes + '分');
        if (seconds > 0) parts.push(seconds + '秒');
        remainText = parts.join('') || '0秒';
      }
    }
    document.getElementById(remainId).textContent = remainText;
    if (updateProgress) {
      const progressRounded = Math.round(progressPercent * 10) / 10;
      document.getElementById(progressId).style.width = progressPercent + '%';
      document.getElementById(percentId).textContent = progressRounded + '%';
    }
  }

  // ===== 🆕 本周剩余（客户端实时计算） =====
  function updateWeekRemain() {
    const now = new Date();
    const w = now.getDay() || 7;
    const daySec = now.getHours() * 3600 + now.getMinutes() * 60 + now.getSeconds();
    const totalSec = (7 - w) * 86400 + (86400 - daySec);
    
    const days = Math.floor(totalSec / 86400);
    const hours = Math.floor((totalSec % 86400) / 3600);
    const mins = Math.floor((totalSec % 3600) / 60);
    const secs = Math.floor(totalSec % 60);
    
    document.getElementById('weekRemain').textContent = 
      days + '天' + hours + '时' + mins + '分' + secs + '秒';
    
    const weekElapsed = (w - 1) * 86400 + daySec;
    const weekTotal = 7 * 86400;
    const weekProgress = Math.round((weekElapsed / weekTotal) * 1000) / 10;
    document.getElementById('weekProgressFill').style.width = weekProgress + '%';
    document.getElementById('weekPercent').textContent = weekProgress + '%';
  }

  // ===== 更新年/月/节日倒计时 =====
  function updateCountdown(updateProgress) {
    const now = Date.now();
    updateItem('yearRemain', 'yearProgressFill', 'yearPercent', yearStart, yearEnd, now, updateProgress);
    updateItem('monthRemain', 'monthProgressFill', 'monthPercent', monthStart, monthEnd, now, updateProgress);
    if (holidayTarget !== null) {
      const diff = holidayTarget - now;
      if (diff > 0) {
        const days = Math.floor(diff / (1000 * 60 * 60 * 24));
        document.getElementById('holidayRemain').textContent = days;
      } else {
        document.getElementById('holidayRemain').textContent = '0';
      }
    }
  }

  // ===== 启动所有定时器 =====
  updateClock();
  setInterval(updateClock, 1000);
  
  updateWeekRemain();
  setInterval(updateWeekRemain, 1000);
  
  updateCountdown(true);
  setInterval(() => {
    updateCountdown(true);
  }, 60000);
</script>