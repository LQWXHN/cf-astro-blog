---
import Base from "@/layouts/Base.astro";
---

<Base title="便签墙" description="自由书写的便签墙" fullscreen={true}>
  <div id="board"></div>

  <!-- 底部输入框 -->
  <div id="note-input-container">
    <input id="note-input" type="text" placeholder="写下你想说的话..." maxlength="30" />
    <div class="color-picker-wrapper">
      <span class="color-label">颜色</span>
      <div class="color-options" id="colorOptions">
        <span class="color-swatch active" data-color="#fef3c7" style="background:#fef3c7; border-color:#f59e0b;"></span>
        <span class="color-swatch" data-color="#dbeafe" style="background:#dbeafe; border-color:#3b82f6;"></span>
        <span class="color-swatch" data-color="#d1fae5" style="background:#d1fae5; border-color:#10b981;"></span>
        <span class="color-swatch" data-color="#fce7f3" style="background:#fce7f3; border-color:#ec4899;"></span>
        <span class="color-swatch" data-color="#ede9fe" style="background:#ede9fe; border-color:#8b5cf6;"></span>
        <span class="color-swatch" data-color="#fed7aa" style="background:#fed7aa; border-color:#f97316;"></span>
      </div>
    </div>
    <button id="note-submit">添加</button>
    <span id="char-count">0/30</span>
  </div>
</Base>

<style is:global>
  /* ===== 便签墙专属样式 ===== */
  body {
    overflow: hidden;
    background-image: linear-gradient(0deg, rgba(200,200,200,0.12) 1px, transparent 0),
                      linear-gradient(90deg, rgba(200,200,200,0.12) 1px, transparent 0);
    background-size: 30px 30px;
  }

  #board {
    position: relative;
    width: 100vw;
    height: 100dvh;
    overflow: hidden;
  }

  /* ===== 卡片样式 ===== */
  .card {
    position: absolute;
    width: 220px;
    border-radius: var(--radius, 16px);
    box-shadow: var(--shadow-soft, 0 16px 35px rgba(0,0,0,0.12));
    border: 1px solid var(--color-border, rgba(0,0,0,0.06));
    overflow: hidden;
    transform-origin: center;
    transition: transform 0.35s cubic-bezier(0.25, 0.8, 0.25, 1),
                opacity 0.35s ease,
                left 0.35s ease,
                top 0.35s ease,
                width 0.35s ease,
                height 0.35s ease,
                border-radius 0.35s ease;
    opacity: 0;
  }

  .card.dragging {
    transition: none;
    box-shadow: var(--shadow-strong, 0 22px 45px rgba(0,0,0,0.25));
  }

  .card.maximized {
    position: fixed;
    inset: 0;
    width: 100vw;
    height: 100dvh;
    border-radius: 0 !important;
    box-shadow: var(--shadow-strong, 0 28px 60px rgba(0,0,0,0.3));
    z-index: 999999;
  }

  .card.maximized .card-body {
    font-size: clamp(48px, 18vw, 200px);
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: clamp(32px, 10vw, 128px);
  }

  .card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 8px 12px;
    background: rgba(255, 255, 255, 0.5);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    cursor: grab;
    user-select: none;
    touch-action: pan-y;
    border-bottom: 1px solid rgba(0,0,0,0.04);
  }

  .card-header.dragging {
    cursor: grabbing;
  }

  .card-title {
    font-size: 12px;
    font-weight: 600;
    color: rgba(0, 0, 0, 0.35);
    padding-left: 10px;
    flex: 1;
    letter-spacing: 0.02em;
  }

  .card-body {
    padding: 16px 18px;
    font-size: 16px;
    line-height: 1.5;
    font-weight: 500;
    color: rgba(0, 0, 0, 0.7);
    word-break: break-word;
    overflow-wrap: anywhere;
    white-space: normal;
    min-height: 60px;
  }

  /* ===== 窗口控制按钮 ===== */
  .window-controls {
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .window-controls .control {
    position: relative;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    border: 1px solid rgba(0, 0, 0, 0.08);
    background: #ccc;
    cursor: pointer;
    outline: none;
    padding: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.15s ease;
  }

  .window-controls .control:hover {
    transform: scale(1.15);
  }

  .window-controls .control.close {
    background: #ff5f57;
    border-color: #e0443e;
  }

  .window-controls .control.minimize {
    background: #febb2e;
    border-color: #dea123;
  }

  .window-controls .control.maximize {
    background: #28c840;
    border-color: #1aab2c;
  }

  .window-controls .control::after {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    opacity: 0;
    transition: opacity 0.2s ease;
  }

  .card-header:hover .window-controls .control::after {
    opacity: 0.8;
  }

  .window-controls .control.close::after {
    content: '×';
    font-size: 10px;
    font-weight: 700;
    color: rgba(0, 0, 0, 0.5);
  }

  .window-controls .control.minimize::after {
    width: 6px;
    height: 2px;
    background: rgba(0, 0, 0, 0.4);
  }

  .window-controls .control.maximize::after {
    width: 6px;
    height: 6px;
    background: linear-gradient(45deg, rgba(0,0,0,0.4) 0%, rgba(0,0,0,0.4) 45%, transparent 45%, transparent 55%, rgba(0,0,0,0.4) 55%, rgba(0,0,0,0.4) 100%);
  }

  /* ===== 颜色选择器 ===== */
  .color-picker-wrapper {
    display: flex;
    align-items: center;
    gap: 6px;
    flex-shrink: 0;
  }
  .color-label {
    font-size: 12px;
    color: rgba(0,0,0,0.4);
    margin-right: 2px;
  }
  .color-options {
    display: flex;
    gap: 4px;
  }
  .color-swatch {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    border: 2px solid transparent;
    cursor: pointer;
    transition: all 0.2s;
    flex-shrink: 0;
  }
  .color-swatch:hover {
    transform: scale(1.1);
  }
  .color-swatch.active {
    border-color: #333;
    box-shadow: 0 0 0 2px rgba(0,0,0,0.1);
  }
  [data-theme="dark"] .color-swatch.active {
    border-color: #fff;
  }
  [data-theme="dark"] .color-label {
    color: rgba(255,255,255,0.4);
  }

  /* ===== 底部输入框 ===== */
  #note-input-container {
    position: fixed;
    left: 50%;
    bottom: 40px;
    transform: translateX(-50%);
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 16px;
    border-radius: var(--radius, 16px);
    background: rgba(255, 255, 255, 0.25);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid rgba(255, 255, 255, 0.3);
    box-shadow: var(--shadow-soft, 0 4px 20px rgba(0,0,0,0.08));
    z-index: 1000001;
    transition: all 0.3s ease;
  }

  #note-input-container:focus-within {
    background: rgba(255, 255, 255, 0.4);
    border-color: var(--color-accent, rgba(10,132,255,0.3));
    box-shadow: var(--shadow-strong, 0 8px 30px rgba(0,0,0,0.12));
  }

  #note-input {
    flex: 1;
    font-size: 15px;
    padding: 10px 14px;
    border: none;
    border-radius: var(--radius-sm, 12px);
    outline: none;
    background: rgba(255, 255, 255, 0.2);
    color: var(--color-text, #333);
    min-width: 200px;
    transition: all 0.2s ease;
    font-family: inherit;
  }

  #note-input::placeholder {
    color: rgba(0, 0, 0, 0.35);
  }

  #note-input:focus {
    background: rgba(255, 255, 255, 0.4);
  }

  #char-count {
    font-size: 12px;
    color: rgba(0, 0, 0, 0.3);
    min-width: 32px;
    text-align: center;
    font-variant-numeric: tabular-nums;
  }

  #char-count.warning {
    color: var(--color-warning, #d97706);
  }

  #char-count.danger {
    color: var(--color-danger, #dc2626);
  }

  #note-submit {
    font-size: 15px;
    padding: 10px 20px;
    border: none;
    border-radius: var(--radius-sm, 12px);
    cursor: pointer;
    background: var(--color-accent, rgba(76, 175, 80, 0.8));
    color: white;
    font-weight: 600;
    backdrop-filter: blur(6px);
    transition: all 0.25s ease;
    box-shadow: 0 2px 8px rgba(76, 175, 80, 0.25);
  }

  #note-submit:hover {
    background: var(--color-accent-hover, rgba(76, 175, 80, 1));
    transform: translateY(-1px);
    box-shadow: 0 4px 14px rgba(76, 175, 80, 0.35);
  }

  #note-submit:active {
    transform: translateY(0);
  }

  /* ===== 暗色模式适配 ===== */
  [data-theme="dark"] #note-input-container {
    background: rgba(30, 40, 60, 0.5);
    border-color: rgba(255, 255, 255, 0.08);
  }

  [data-theme="dark"] #note-input {
    background: rgba(255, 255, 255, 0.06);
    color: var(--color-text, #eef4ff);
  }

  [data-theme="dark"] #note-input::placeholder {
    color: rgba(255, 255, 255, 0.25);
  }

  [data-theme="dark"] .card {
    border-color: rgba(255, 255, 255, 0.06);
  }

  [data-theme="dark"] .card-body {
    color: rgba(255, 255, 255, 0.8);
  }

  [data-theme="dark"] .card-header {
    background: rgba(30, 40, 60, 0.5);
  }

  [data-theme="dark"] .card-title {
    color: rgba(255, 255, 255, 0.3);
  }

  [data-theme="dark"] .color-swatch.active {
    border-color: #fff;
  }
  [data-theme="dark"] .color-label {
    color: rgba(255,255,255,0.4);
  }

  /* ===== 响应式 ===== */
  @media (max-width: 768px) {
    .card {
      width: 170px;
      border-radius: 12px;
    }
    .card-body {
      padding: 12px 14px;
      font-size: 14px;
    }
    #note-input-container {
      bottom: 20px;
      padding: 8px 12px;
      gap: 6px;
      width: calc(100% - 32px);
      border-radius: 14px;
      flex-wrap: wrap;
      justify-content: center;
    }
    #note-input {
      min-width: 120px;
      font-size: 14px;
      padding: 8px 12px;
      flex: 1 1 140px;
    }
    #note-submit {
      font-size: 14px;
      padding: 8px 14px;
    }
    .color-picker-wrapper {
      gap: 4px;
    }
    .color-swatch {
      width: 22px;
      height: 22px;
    }
    .color-label {
      font-size: 10px;
    }
    .color-options {
      gap: 3px;
    }
  }

  @media (max-width: 480px) {
    #note-input-container {
      bottom: 12px;
      padding: 6px 10px;
      gap: 4px;
      width: calc(100% - 16px);
      border-radius: 12px;
    }
    #note-input {
      min-width: 80px;
      font-size: 13px;
      padding: 6px 10px;
    }
    #note-submit {
      font-size: 13px;
      padding: 6px 12px;
    }
    .color-swatch {
      width: 18px;
      height: 18px;
    }
    .color-label {
      font-size: 9px;
    }
    #char-count {
      font-size: 10px;
      min-width: 24px;
    }
  }
</style>

<script>
  // ===== 便签墙交互逻辑 =====
  const board = document.getElementById('board');

  const COLOR_MAP = {
    yellow: '#fef3c7',
    blue: '#dbeafe',
    green: '#d1fae5',
    pink: '#fce7f3',
    purple: '#ede9fe',
    orange: '#fed7aa',
    red: '#fecaca',
    gray: '#e5e7eb',
  };

  const cardStates = new WeakMap();
  let activeMaximizedCard = null;
  let zIndexCursor = 200;
  const MAXIMIZED_LAYER = 1000000;
  let isMobile = window.matchMedia('(pointer: coarse)').matches || window.innerWidth <= 768;
  let selectedColor = '#fef3c7';

  // ===== 颜色选择器 =====
  document.querySelectorAll('.color-swatch').forEach(el => {
    el.addEventListener('click', function() {
      document.querySelectorAll('.color-swatch').forEach(s => s.classList.remove('active'));
      this.classList.add('active');
      selectedColor = this.dataset.color;
    });
  });

  function randomFrom(arr) { return arr[Math.floor(Math.random() * arr.length)]; }
  function clamp(v, min, max) { return Math.min(Math.max(v, min), max); }

  function applyTransform(card, state) {
    const scale = state.scale ?? 1;
    const angle = state.angle ?? 0;
    card.style.transform = `scale(${scale}) rotate(${angle}deg)`;
  }

  function bringToFront(card) {
    if (card === activeMaximizedCard) {
      card.style.zIndex = MAXIMIZED_LAYER;
      return;
    }
    zIndexCursor += 1;
    if (activeMaximizedCard && zIndexCursor >= MAXIMIZED_LAYER) {
      zIndexCursor = MAXIMIZED_LAYER - 1;
    }
    card.style.zIndex = zIndexCursor;
  }

  function setupCardInteractions(card) {
    const header = card.querySelector('.card-header');
    const closeBtn = card.querySelector('.control.close');
    const minimizeBtn = card.querySelector('.control.minimize');
    const maximizeBtn = card.querySelector('.control.maximize');

    closeBtn?.addEventListener('click', (e) => { e.stopPropagation(); closeCard(card); });
    minimizeBtn?.addEventListener('click', (e) => { e.stopPropagation(); minimizeCard(card); });
    maximizeBtn?.addEventListener('click', (e) => { e.stopPropagation(); toggleMaximize(card); });

    header?.addEventListener('pointerdown', (e) => {
      if (e.pointerType === 'touch') return;
      startDrag(e, card);
    });

    card.addEventListener('pointerdown', () => bringToFront(card));

    header?.addEventListener('dblclick', (e) => {
      if (!e.target.closest('.control')) toggleMaximize(card);
    });
  }

  function closeCard(card) {
    const state = cardStates.get(card);
    if (!state || state.closing) return;
    if (card === activeMaximizedCard) activeMaximizedCard = null;
    state.closing = true;
    state.scale = 0.1;
    card.style.opacity = '0';
    applyTransform(card, state);
    card.addEventListener('transitionend', () => card.remove(), { once: true });
  }

  function minimizeCard(card) {
    const state = cardStates.get(card);
    if (!state || state.closing) return;

    const runMinimize = () => {
      state.closing = true;
      bringToFront(card);
      const bottom = Math.max(window.innerHeight - 24, 0);
      const targetLeft = clamp(state.left, 16, Math.max(window.innerWidth - card.offsetWidth - 16, 16));
      state.left = targetLeft;
      state.top = bottom;
      state.scale = 0.1;
      state.angle = 0;
      card.style.left = targetLeft + 'px';
      card.style.top = bottom + 'px';
      card.style.opacity = '0.35';
      applyTransform(card, state);
      card.addEventListener('transitionend', () => card.remove(), { once: true });
    };

    if (state.maximized) {
      activeMaximizedCard = null;
      state.maximized = false;
      card.classList.remove('maximized');
      card.style.borderRadius = '';
      state.left = 0; state.top = 0; state.scale = 1; state.angle = 0;
      applyTransform(card, state);
      requestAnimationFrame(() => requestAnimationFrame(runMinimize));
      return;
    }
    runMinimize();
  }

  function toggleMaximize(card) {
    const state = cardStates.get(card);
    if (!state || state.closing) return;
    state.maximized ? restoreFromMaximize(card, state) : maximizeCard(card, state);
  }

  function maximizeCard(card, state) {
    if (activeMaximizedCard && activeMaximizedCard !== card) {
      const s = cardStates.get(activeMaximizedCard);
      if (s) restoreFromMaximize(activeMaximizedCard, s);
    }
    state.beforeMaximize = {
      left: state.left, top: state.top, scale: state.scale ?? 1,
      width: card.offsetWidth, height: card.offsetHeight, angle: state.angle ?? 0
    };
    card.classList.add('maximized');
    card.style.left = '0px';
    card.style.top = '0px';
    card.style.width = window.innerWidth + 'px';
    card.style.height = window.innerHeight + 'px';
    state.left = 0; state.top = 0; state.scale = 1; state.angle = 0;
    applyTransform(card, state);
    activeMaximizedCard = card;
    bringToFront(card);
    state.maximized = true;
  }

  function restoreFromMaximize(card, state) {
    const prev = state.beforeMaximize;
    if (!prev) return;
    card.classList.remove('maximized');
    card.style.left = prev.left + 'px';
    card.style.top = prev.top + 'px';
    card.style.width = prev.width + 'px';
    card.style.height = prev.height + 'px';
    state.left = prev.left;
    state.top = prev.top;
    state.scale = prev.scale ?? 1;
    state.angle = prev.angle ?? state.angle ?? 0;
    applyTransform(card, state);
    state.maximized = false;
    if (activeMaximizedCard === card) activeMaximizedCard = null;
    bringToFront(card);
    setTimeout(() => {
      if (!state.maximized) {
        card.style.width = '';
        card.style.height = '';
        card.style.borderRadius = '';
      }
    }, 360);
  }

  function startDrag(event, card) {
    const state = cardStates.get(card);
    if (!state || state.closing || state.maximized) return;
    const header = card.querySelector('.card-header');
    card.classList.add('dragging');
    header?.classList.add('dragging');
    state.dragging = true;
    state.dragOffsetX = event.clientX - state.left;
    state.dragOffsetY = event.clientY - state.top;

    let dragFrame = null;
    let pendingLeft = state.left, pendingTop = state.top;

    const commitDrag = () => {
      dragFrame = null;
      const maxLeft = Math.max(window.innerWidth - card.offsetWidth, 0);
      const maxTop = Math.max(window.innerHeight - card.offsetHeight, 0);
      state.left = clamp(pendingLeft, -card.offsetWidth * 0.4, maxLeft);
      state.top = clamp(pendingTop, -card.offsetHeight * 0.4, maxTop);
      card.style.left = state.left + 'px';
      card.style.top = state.top + 'px';
    };

    const onMove = (e) => {
      if (!state.dragging) return;
      pendingLeft = e.clientX - state.dragOffsetX;
      pendingTop = e.clientY - state.dragOffsetY;
      if (dragFrame === null) dragFrame = requestAnimationFrame(commitDrag);
    };

    const onUp = () => {
      state.dragging = false;
      card.classList.remove('dragging');
      header?.classList.remove('dragging');
      if (dragFrame !== null) { cancelAnimationFrame(dragFrame); commitDrag(); }
      document.removeEventListener('pointermove', onMove);
      document.removeEventListener('pointerup', onUp);
    };

    document.addEventListener('pointermove', onMove);
    document.addEventListener('pointerup', onUp);
  }

  // ===== 从 API 加载便签（分批出现） =====
  async function fetchNotes() {
    try {
      const res = await fetch('/api/notes');
      const data = await res.json();
      if (Array.isArray(data) && data.length > 0) {
        const batchSize = 4;
        let index = 0;
        const interval = setInterval(() => {
          const batch = data.slice(index, index + batchSize);
          if (batch.length === 0) {
            clearInterval(interval);
            return;
          }
          batch.forEach(note => {
            const color = note.color || '#fef3c7';
            createCard(note.content, color, note.positionLeft, note.positionTop, note.rotation);
          });
          index += batchSize;
        }, 300);
      }
    } catch (e) {
      console.error('加载便签失败:', e);
    }
  }

  // ===== 创建卡片（随机位置） =====
function createCard(message, color, posLeft, posTop, rotation) {
  const card = document.createElement('div');
  card.className = 'card';

  const bgColor = color || '#fef3c7';
  const angle = rotation ?? (Math.random() - 0.5) * 8;
  const cardWidth = isMobile ? 170 : 220;
  const cardHeight = isMobile ? 130 : 140;
  const hm = isMobile ? 12 : 16;
  const vm = isMobile ? 12 : 20;

  // 随机位置（如果传入了位置则使用传入值）
  let left, top;
  if (posLeft !== undefined && posTop !== undefined) {
    left = posLeft / 100 * (window.innerWidth - cardWidth);
    top = posTop / 100 * (window.innerHeight - cardHeight);
  } else {
    left = hm + Math.random() * Math.max(window.innerWidth - cardWidth - hm * 2, 0);
    top = vm + Math.random() * Math.max(window.innerHeight - cardHeight - vm * 2, 0);
  }

  // 边界保护
  const finalLeft = Math.max(10, Math.min(window.innerWidth - cardWidth - 10, left));
  const finalTop = Math.max(10, Math.min(window.innerHeight - cardHeight - 10, top));

  card.style.background = bgColor;
  card.style.left = finalLeft + 'px';
  card.style.top = finalTop + 'px';
  card.style.zIndex = ++zIndexCursor;

  card.innerHTML = `
    <div class="card-header">
      <div class="window-controls">
        <button class="control close" type="button" aria-label="关闭"></button>
        <button class="control minimize" type="button" aria-label="最小化"></button>
        <button class="control maximize" type="button" aria-label="最大化"></button>
      </div>
      <div class="card-title">便签</div>
    </div>
    <div class="card-body">${message}</div>
  `;

  const state = {
    angle, scale: isMobile ? 0.85 : 0.7,
    left: finalLeft, top: finalTop,
    maximized: false,
    closing: false,
    lastPosition: { left: finalLeft, top: finalTop }
  };

  cardStates.set(card, state);
  applyTransform(card, state);
  board.appendChild(card);

  requestAnimationFrame(() => {
    state.scale = 1;
    applyTransform(card, state);
    card.style.opacity = '1';
  });

  setupCardInteractions(card);
}

  // ===== 提交便签（使用选中的颜色） =====
  async function sendNote() {
    const input = document.getElementById('note-input');
    const text = input.value.trim();
    if (!text) return;

    try {
      const res = await fetch('/api/notes', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ content: text, color: selectedColor })
      });
      const result = await res.json();
      if (result.success) {
        createCard(text, selectedColor);
        input.value = '';
        updateCharCount();
      } else {
        alert(result.error || '添加失败');
      }
    } catch (e) {
      console.error('网络错误:', e);
      alert('网络错误，请稍后重试');
    }
  }

  // ===== 字符计数 =====
  function updateCharCount() {
    const input = document.getElementById('note-input');
    const count = document.getElementById('char-count');
    const len = input.value.length;
    count.textContent = len + '/30';
    count.classList.toggle('warning', len > 20);
    count.classList.toggle('danger', len > 28);
  }

  // ===== 初始化 =====
  fetchNotes();

  const noteInput = document.getElementById('note-input');
  const noteSubmit = document.getElementById('note-submit');

  noteInput.addEventListener('input', updateCharCount);
  noteSubmit.addEventListener('click', sendNote);
  noteInput.addEventListener('keydown', (e) => { if (e.key === 'Enter') sendNote(); });

  window.addEventListener('resize', () => {
    isMobile = window.matchMedia('(pointer: coarse)').matches || window.innerWidth <= 768;
    document.body.classList.toggle('is-mobile', isMobile);
    document.querySelectorAll('.card.maximized').forEach(card => {
      card.style.width = window.innerWidth + 'px';
      card.style.height = window.innerHeight + 'px';
    });
  });
</script>