---
import { env } from "cloudflare:workers";
import { asc, eq } from "drizzle-orm";
import { toolCategories, toolItems } from "@/db/schema";
import Base from "@/layouts/Base.astro";
import { getDb } from "@/lib/db";

// 获取所有分类及其工具
const db = getDb(env.DB);
const categoriesWithItems = await db
  .select({
    id: toolCategories.id,
    name: toolCategories.name,
    sortOrder: toolCategories.sortOrder,
  })
  .from(toolCategories)
  .orderBy(asc(toolCategories.sortOrder), asc(toolCategories.name));

const allTools = await db
  .select({
    id: toolItems.id,
    name: toolItems.name,
    description: toolItems.description,
    url: toolItems.url,
    icon: toolItems.icon,
    categoryId: toolItems.categoryId,
    sortOrder: toolItems.sortOrder,
  })
  .from(toolItems)
  .orderBy(asc(toolItems.categoryId), asc(toolItems.sortOrder), asc(toolItems.name));

// 按分类分组
const categorized = categoriesWithItems.map((cat) => ({
  ...cat,
  items: allTools.filter((tool) => tool.categoryId === cat.id),
}));
---

<Base title="工具箱" description="常用的工具，点击直达">
  <section class="tools-hero glass-panel">
    <span class="section-kicker">工具箱</span>
    <h1 class="page-title">工具箱</h1>
    <p class="page-intro">常用的工具，点击直达</p>
  </section>

  {
    categorized.map((category) => (
      <section class="tools-category-section glass-panel">
        <div class="tools-category-head">
          <span class="tools-category-kicker">{category.name}</span>
        </div>
        <div class="tools-grid">
          {
            category.items.map((tool) => (
              <a
                href={tool.url}
                target="_blank"
                rel="noopener noreferrer"
                class="tool-card"
              >
                <div class="tool-card-icon">
                  {tool.icon ? (
                    <img src={tool.icon} alt={tool.name} loading="lazy" />
                  ) : (
                    <span class="tool-icon-placeholder">{tool.name.slice(0, 1)}</span>
                  )}
                </div>
                <div class="tool-card-body">
                  <h2 class="tool-card-name">{tool.name}</h2>
                  {tool.description && <p class="tool-card-desc">{tool.description}</p>}
                </div>
              </a>
            ))
          }
        </div>
      </section>
    ))
  }
</Base>

<style>
  /* ... 和之前相同的样式，你可以复用之前的 CSS ... */
  .tools-hero { /* ... */ }
  .tools-category-section { /* ... */ }
  .tools-grid { /* ... */ }
  .tool-card { /* ... */ }
  /* 增加图标占位符样式 */
  .tool-icon-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 1.2rem;
    color: var(--color-text-muted);
  }
</style>