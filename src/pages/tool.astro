---
import { env } from "cloudflare:workers";
import { asc, eq } from "drizzle-orm";
import { toolCategories, toolItems } from "@/db/schema";
import Base from "@/layouts/Base.astro";
import { getDb } from "@/lib/db";

// 获取 URL 查询参数 q
const searchQuery = Astro.url.searchParams.get("q") || "";
const lowerQuery = searchQuery.toLowerCase().trim();

// 获取所有分类及其工具
const db = getDb(env.DB);
const categories = await db
  .select({
    id: toolCategories.id,
    name: toolCategories.name,
    sortOrder: toolCategories.sortOrder,
  })
  .from(toolCategories)
  .orderBy(asc(toolCategories.sortOrder), asc(toolCategories.name));

const allTools = await db
  .select({
    id: toolItems.id,
    name: toolItems.name,
    description: toolItems.description,
    url: toolItems.url,
    icon: toolItems.icon,
    categoryId: toolItems.categoryId,
    sortOrder: toolItems.sortOrder,
  })
  .from(toolItems)
  .orderBy(asc(toolItems.categoryId), asc(toolItems.sortOrder), asc(toolItems.name));

// 按关键词过滤工具
let filteredTools = allTools;
if (lowerQuery) {
  filteredTools = allTools.filter(
    (tool) =>
      tool.name.toLowerCase().includes(lowerQuery) ||
      (tool.description && tool.description.toLowerCase().includes(lowerQuery))
  );
}

// 按分类分组（只包含匹配的工具）
const categorized = categories
  .map((cat) => ({
    ...cat,
    items: filteredTools.filter((tool) => tool.categoryId === cat.id),
  }))
  .filter((cat) => cat.items.length > 0); // 隐藏空分类

const totalFound = filteredTools.length;
---

<Base title="百宝箱" description="常用的工具，点击直达">
  <section class="tools-hero glass-panel">
    <span class="section-kicker">工具箱</span>
    <h1 class="page-title">工具箱</h1>
    <p class="page-intro">常用的工具，点击直达</p>
  </section>

  <!-- ===== 搜索表单（手动搜索） ===== -->
  <section class="tools-search glass-panel">
    <form method="get" action="/tool" class="tools-search-form">
      <div class="tools-search-box">
        <input
          type="text"
          name="q"
          placeholder="输入关键词进行搜索..."
          value={searchQuery}
          class="tools-search-input"
          autocomplete="off"
        />
        <button type="submit" class="tools-search-btn">搜索</button>
        {searchQuery && (
          <a href="/tool" class="tools-search-clear-btn">清除</a>
        )}
      </div>
      {searchQuery && (
        <p class="tools-search-status">
          找到 <strong>{totalFound}</strong> 个匹配的工具
        </p>
      )}
    </form>
  </section>

  <!-- ===== 分类和工具列表 ===== -->
  {categorized.length > 0 ? (
    categorized.map((category) => (
      <section class="tools-category-section glass-panel" data-category-id={category.id}>
        <div class="tools-category-head">
          <span class="tools-category-kicker">{category.name}</span>
          <span class="tools-category-count">{category.items.length} 个工具</span>
        </div>
        <div class="tools-grid">
          {category.items.map((tool) => (
            <a
              href={tool.url}
              target="_blank"
              rel="noopener noreferrer"
              class="tool-card"
              title={tool.name}
            >
              <div class="tool-card-icon">
                {tool.icon ? (
                  <img src={tool.icon} alt={tool.name} loading="lazy" />
                ) : (
                  <span class="tool-icon-placeholder">{tool.name.slice(0, 1)}</span>
                )}
              </div>
              <div class="tool-card-body">
                <h2 class="tool-card-name">{tool.name}</h2>
                {tool.description && <p class="tool-card-desc">{tool.description}</p>}
              </div>
            </a>
          ))}
        </div>
      </section>
    ))
  ) : (
    <section class="tools-category-section glass-panel">
      <div class="tools-category-head">
        <span class="tools-category-kicker">无匹配结果</span>
      </div>
      <div class="empty-state">
        {searchQuery ? `没有找到包含 “${searchQuery}” 的工具` : '请前往后台添加工具分类和工具条目。'}
      </div>
    </section>
  )}
</Base>

<style>
  /* ===== Hero 区域 ===== */
  .tools-hero {
    --glass-panel-opacity: calc(var(--hero-card-opacity, 14) / 100);
    --glass-panel-blur: var(--hero-card-blur, 18px);
    display: grid;
    gap: 0.8rem;
    padding: clamp(1.8rem, 1.5rem + 2vw, 3rem);
    margin-bottom: 1.5rem;
  }

  /* ===== 搜索表单 ===== */
  .tools-search {
    --glass-panel-opacity: calc(var(--hero-card-opacity, 14) / 100);
    --glass-panel-blur: var(--hero-card-blur, 18px);
    padding: 1.2rem 1.5rem;
    margin-bottom: 1.5rem;
  }

  .tools-search-form {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .tools-search-box {
    display: flex;
    gap: 0.6rem;
    align-items: center;
    flex-wrap: wrap;
  }

  .tools-search-input {
    flex: 1;
    min-width: 200px;
    padding: 0.8rem 1.2rem;
    border-radius: var(--radius-pill);
    border: 1px solid var(--color-border);
    background: var(--color-bg-tertiary);
    color: var(--color-text);
    font-size: 0.95rem;
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  .tools-search-input:focus {
    outline: none;
    border-color: var(--color-accent);
    box-shadow: 0 0 0 3px rgba(10, 132, 255, 0.15);
  }

  .tools-search-btn {
    padding: 0.8rem 1.6rem;
    border-radius: var(--radius-pill);
    border: none;
    background: var(--color-accent);
    color: #fff;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.2s, transform 0.1s;
  }

  .tools-search-btn:hover {
    background: var(--color-accent-hover);
  }

  .tools-search-btn:active {
    transform: scale(0.97);
  }

  .tools-search-clear-btn {
    padding: 0.8rem 1.2rem;
    border-radius: var(--radius-pill);
    border: 1px solid var(--color-border);
    background: transparent;
    color: var(--color-text-muted);
    text-decoration: none;
    font-size: 0.9rem;
    transition: background 0.2s;
  }

  .tools-search-clear-btn:hover {
    background: rgba(255, 255, 255, 0.1);
  }

  .tools-search-status {
    margin: 0;
    font-size: 0.95rem;
    color: var(--color-text-secondary);
  }

  .tools-search-status strong {
    color: var(--color-text);
  }

  /* ===== 分类区域 ===== */
  .tools-category-section {
    --glass-panel-opacity: calc(var(--hero-card-opacity, 14) / 100);
    --glass-panel-blur: var(--hero-card-blur, 18px);
    padding: 1.5rem 1.5rem 1.2rem;
    margin-bottom: 1.5rem;
    display: grid;
    gap: 1rem;
  }

  .tools-category-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }

  .tools-category-kicker {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.3rem 0.9rem;
    border-radius: var(--radius-pill);
    background: rgba(10, 132, 255, 0.08);
    border: 1px solid rgba(10, 132, 255, 0.12);
    color: var(--color-accent-hover);
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.04em;
  }

  .tools-category-count {
    font-size: 0.78rem;
    color: var(--color-text-muted);
    background: rgba(255, 255, 255, 0.04);
    padding: 0.2rem 0.7rem;
    border-radius: var(--radius-pill);
    border: 1px solid rgba(255, 255, 255, 0.04);
  }

  /* ===== 工具卡片网格 ===== */
  .tools-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: 1.2rem;
  }

  .tool-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 1.5rem 0.8rem 1.2rem;
    border-radius: var(--radius-inner);
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.06);
    transition: transform 0.3s cubic-bezier(0.22, 1, 0.36, 1), box-shadow 0.3s cubic-bezier(0.22, 1, 0.36, 1), border-color 0.3s cubic-bezier(0.22, 1, 0.36, 1), background-color 0.3s ease;
    text-decoration: none;
    color: var(--color-text);
    min-height: 140px;
    backdrop-filter: blur(2px);
  }

  .tool-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 16px 32px -16px rgba(0, 0, 0, 0.18);
    border-color: rgba(10, 132, 255, 0.25);
    background: rgba(255, 255, 255, 0.06);
  }

  .tool-card-icon {
    width: 52px;
    height: 52px;
    margin-bottom: 0.7rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(255, 255, 255, 0.06);
    border-radius: 9999px;
    padding: 10px;
    border: 1px solid rgba(255, 255, 255, 0.04);
    flex-shrink: 0;
    transition: transform 0.3s ease, background-color 0.3s ease;
  }

  .tool-card:hover .tool-card-icon {
    background: rgba(10, 132, 255, 0.06);
    border-color: rgba(10, 132, 255, 0.12);
    transform: scale(1.04);
  }

  .tool-card-icon img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
  }

  .tool-icon-placeholder {
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--color-text-muted);
  }

  .tool-card-body {
    display: grid;
    gap: 0.15rem;
    width: 100%;
  }

  .tool-card-name {
    font-size: 0.92rem;
    font-weight: 600;
    margin: 0;
    color: var(--color-text);
    letter-spacing: -0.02em;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .tool-card-desc {
    font-size: 0.78rem;
    color: var(--color-text-muted);
    margin: 0;
    line-height: 1.4;
    overflow: hidden;
    text-overflow: ellipsis;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }

  /* ===== 深色主题适配 ===== */
  :global([data-theme="dark"]) .tool-card {
    background: rgba(255, 255, 255, 0.02);
    border-color: rgba(255, 255, 255, 0.04);
  }

  :global([data-theme="dark"]) .tool-card:hover {
    background: rgba(255, 255, 255, 0.06);
    border-color: rgba(87, 166, 255, 0.2);
  }

  :global([data-theme="dark"]) .tools-category-kicker {
    background: rgba(87, 166, 255, 0.08);
    border-color: rgba(87, 166, 255, 0.12);
    color: var(--color-accent);
  }

  :global([data-theme="dark"]) .tool-card-icon {
    background: rgba(255, 255, 255, 0.04);
  }

  /* ===== 空状态 ===== */
  .empty-state {
    padding: 2rem;
    text-align: center;
    color: var(--color-text-muted);
    background: rgba(255, 255, 255, 0.02);
    border-radius: var(--radius-inner);
    border: 1px dashed rgba(255, 255, 255, 0.08);
    width: 100%;
  }

  /* ===== 响应式 ===== */
  @media (max-width: 640px) {
    .tools-grid {
      grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
      gap: 0.8rem;
    }

    .tool-card {
      padding: 1rem 0.6rem 0.8rem;
      min-height: 120px;
    }

    .tool-card-icon {
      width: 44px;
      height: 44px;
      padding: 8px;
    }

    .tool-card-name {
      font-size: 0.82rem;
    }

    .tool-card-desc {
      font-size: 0.72rem;
      -webkit-line-clamp: 2;
    }

    .tools-category-section {
      padding: 0.8rem 0.8rem 0.6rem;
    }

    .tools-category-kicker {
      font-size: 0.78rem;
    }

    .tools-category-count {
      font-size: 0.7rem;
    }

    .tools-search {
      padding: 0.8rem 1rem;
    }

    .tools-search-input {
      padding: 0.6rem 1rem;
      font-size: 0.88rem;
      min-width: 120px;
    }

    .tools-search-btn {
      padding: 0.6rem 1.2rem;
      font-size: 0.88rem;
    }

    .tools-search-clear-btn {
      padding: 0.6rem 1rem;
      font-size: 0.82rem;
    }
  }

  @media (max-width: 420px) {
    .tools-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 0.6rem;
    }
  }
</style>