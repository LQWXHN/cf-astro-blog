---

<Base title="工具箱" description="常用的工具，点击直达">
  <section class="tools-hero glass-panel">
    <span class="section-kicker">🧰 工具箱</span>
    <h1 class="page-title">工具箱</h1>
    <p class="page-intro">常用的工具，点击直达</p>
  </section>

  <!-- 遍历分类 -->
  {
    toolCategories.map((category) => (
      <section class="tools-category-section glass-panel">
        <div class="tools-category-head">
          <span class="tools-category-kicker">{category.name}</span>
        </div>
        <div class="tools-grid">
          {
            category.items.map((tool) => (
              <a
                href={tool.url}
                target="_blank"
                rel="noopener noreferrer"
                class="tool-card"
              >
                <div class="tool-card-icon">
                  <img src={tool.icon} alt={tool.name} loading="lazy" />
                </div>
                <div class="tool-card-body">
                  <h2 class="tool-card-name">{tool.name}</h2>
                  <p class="tool-card-desc">{tool.description}</p>
                </div>
              </a>
            ))
          }
        </div>
      </section>
    ))
  }
</Base>

<style>
  /* ---------- Hero 区域 ---------- */
  .tools-hero {
    --glass-panel-opacity: calc(var(--hero-card-opacity, 14) / 100);
    --glass-panel-blur: var(--hero-card-blur, 18px);
    display: grid;
    gap: 1rem;
    padding: clamp(1.5rem, 1rem + 2vw, 2.5rem);
    margin-bottom: 1.2rem;
  }

  /* ---------- 分类区域 ---------- */
  .tools-category-section {
    --glass-panel-opacity: calc(var(--hero-card-opacity, 14) / 100);
    --glass-panel-blur: var(--hero-card-blur, 18px);
    padding: 1.2rem 1.2rem 0.6rem 1.2rem;
    margin-bottom: 1.2rem;
    display: grid;
    gap: 0.6rem;
  }

  .tools-category-head {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding-bottom: 0.4rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }

  .tools-category-kicker {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.32rem 0.9rem;
    border-radius: var(--radius-pill);
    background: rgba(10, 132, 255, 0.08);
    border: 1px solid rgba(10, 132, 255, 0.12);
    color: var(--color-accent-hover);
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.06em;
  }

  .tools-category-kicker::before {
    content: "·";
    font-weight: 700;
    opacity: 0.6;
  }

  /* ---------- 工具卡片网格 ---------- */
  .tools-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: 0.8rem;
  }

  .tool-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 1.2rem 0.8rem;
    border-radius: var(--radius-inner);
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.06);
    transition:
      transform 0.25s cubic-bezier(0.22, 1, 0.36, 1),
      box-shadow 0.25s cubic-bezier(0.22, 1, 0.36, 1),
      border-color 0.25s cubic-bezier(0.22, 1, 0.36, 1),
      background-color 0.25s ease;
    text-decoration: none;
    color: var(--color-text);
    min-height: 130px;
  }

  .tool-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-soft);
    border-color: rgba(10, 132, 255, 0.22);
    background: rgba(255, 255, 255, 0.08);
  }

  .tool-card-icon {
    width: 44px;
    height: 44px;
    margin-bottom: 0.6rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-bg-tertiary);
    border-radius: 9999px;
    padding: 8px;
    border: 1px solid rgba(255, 255, 255, 0.06);
    flex-shrink: 0;
  }

  .tool-card-icon img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
  }

  .tool-card-body {
    display: grid;
    gap: 0.15rem;
    width: 100%;
  }

  .tool-card-name {
    font-size: 0.92rem;
    font-weight: 600;
    margin: 0;
    color: var(--color-text);
    letter-spacing: -0.02em;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .tool-card-desc {
    font-size: 0.76rem;
    color: var(--color-text-muted);
    margin: 0;
    line-height: 1.4;
    overflow: hidden;
    text-overflow: ellipsis;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }

  /* ---------- 深色主题适配 ---------- */
  :global([data-theme="dark"]) .tool-card {
    background: rgba(255, 255, 255, 0.03);
    border-color: rgba(255, 255, 255, 0.05);
  }

  :global([data-theme="dark"]) .tool-card:hover {
    background: rgba(255, 255, 255, 0.08);
    border-color: rgba(87, 166, 255, 0.2);
  }

  :global([data-theme="dark"]) .tools-category-kicker {
    background: rgba(87, 166, 255, 0.1);
    border-color: rgba(87, 166, 255, 0.15);
    color: var(--color-accent);
  }

  /* 系统深色模式适配 */
  @media (prefers-color-scheme: dark) {
    :global(:root:not([data-theme="light"])) .tool-card {
      background: rgba(255, 255, 255, 0.03);
      border-color: rgba(255, 255, 255, 0.05);
    }

    :global(:root:not([data-theme="light"])) .tool-card:hover {
      background: rgba(255, 255, 255, 0.08);
      border-color: rgba(87, 166, 255, 0.2);
    }

    :global(:root:not([data-theme="light"])) .tools-category-kicker {
      background: rgba(87, 166, 255, 0.1);
      border-color: rgba(87, 166, 255, 0.15);
      color: var(--color-accent);
    }
  }

  /* ---------- 响应式 ---------- */
  @media (max-width: 640px) {
    .tools-grid {
      grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
      gap: 0.6rem;
    }

    .tool-card {
      padding: 1rem 0.6rem;
      min-height: 110px;
    }

    .tool-card-icon {
      width: 38px;
      height: 38px;
      padding: 6px;
    }

    .tool-card-name {
      font-size: 0.82rem;
    }

    .tool-card-desc {
      font-size: 0.7rem;
      -webkit-line-clamp: 2;
    }

    .tools-category-section {
      padding: 0.8rem 0.8rem 0.4rem 0.8rem;
    }
  }

  @media (max-width: 420px) {
    .tools-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>