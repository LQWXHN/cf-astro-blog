<style>
  .wallpaper-container {
    --bg-color: #050505;
    --surface-color: rgba(25, 25, 25, 0.6);
    --surface-border: rgba(255, 255, 255, 0.08);
    --text-main: #ffffff;
    --text-muted: #a1a1aa;
    --accent-color: #3b82f6;
    --accent-hover: #2563eb;
    --radius-lg: 16px;
    --radius-md: 12px;
    --radius-sm: 8px;
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    min-height: 100vh;
  }

  .ambient-bg {
    position: fixed;
    top: 0; left: 0; right: 0; bottom: 0;
    z-index: -1;
    background:
      radial-gradient(circle at 15% 50%, rgba(59, 130, 246, 0.15), transparent 25%),
      radial-gradient(circle at 85% 30%, rgba(147, 51, 234, 0.15), transparent 25%);
    filter: blur(60px);
    animation: pulse 10s ease-in-out infinite alternate;
  }

  @keyframes pulse {
    0% { transform: scale(1); }
    100% { transform: scale(1.1); }
  }

  .wallpaper-container .container {
    max-width: 1600px;
    margin: 0 auto;
    padding: 2rem 2%;
  }

  .header {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    margin-bottom: 3rem;
    animation: slideDown 0.6s ease-out;
  }

  @keyframes slideDown {
    from { opacity: 0; transform: translateY(-20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .header h1 {
    font-size: 2.5rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    margin-bottom: 0.5rem;
    background: linear-gradient(to right, #fff, #a1a1aa);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .header p { color: var(--text-muted); font-size: 1rem; margin-bottom: 0.5rem; }

  .stats-pill {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 1rem 1.5rem;
    padding: 0.5rem 1.5rem;
    background: var(--surface-color);
    backdrop-filter: blur(12px);
    border: 1px solid var(--surface-border);
    border-radius: 9999px;
    color: var(--text-muted);
    font-size: 0.875rem;
  }

  .stat-item strong { color: #fff; font-weight: 600; }

  .api-doc-link {
    background: var(--accent-color);
    color: #fff !important;
    padding: 0.4rem 1rem;
    border-radius: 9999px;
    text-decoration: none;
    font-weight: 500;
    font-size: 0.8rem;
    transition: all 0.2s;
  }

  .api-doc-link:hover {
    background: var(--accent-hover);
    transform: translateY(-2px);
    box-shadow: 0 6px 16px rgba(59, 130, 246, 0.4);
  }

  .filter-section { margin-bottom: 2rem; }

  .section-title {
    font-size: 1.25rem;
    font-weight: 700;
    margin-bottom: 1rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .country-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .tag {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.35rem 0.8rem;
    background: var(--surface-color);
    border: 1px solid var(--surface-border);
    border-radius: 9999px;
    color: var(--text-muted);
    text-decoration: none;
    font-size: 0.8rem;
    transition: all 0.2s;
  }

  .tag:hover { border-color: var(--accent-color); color: #fff; }
  .tag.active { background: var(--accent-color); border-color: var(--accent-color); color: #fff; }
  .tag .count {
    background: rgba(255,255,255,0.1);
    padding: 0 0.4rem;
    border-radius: 9999px;
    font-size: 0.7rem;
  }

  .gallery {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 1.2rem;
  }

  .card {
    background: var(--surface-color);
    border: 1px solid var(--surface-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    cursor: pointer;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    position: relative;
  }

  .card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(0,0,0,0.5);
    border-color: rgba(255,255,255,0.2);
  }

  .badge-date {
    position: absolute;
    top: 0.6rem;
    right: 0.6rem;
    background: rgba(0,0,0,0.7);
    backdrop-filter: blur(8px);
    padding: 0.2rem 0.6rem;
    border-radius: 9999px;
    font-size: 0.6rem;
    color: #fff;
    z-index: 2;
    letter-spacing: 0.02em;
  }

  .card-img-wrapper {
    position: relative;
    width: 100%;
    padding-top: 56.25%;
    overflow: hidden;
  }

  .card-img-wrapper img {
    position: absolute;
    top: 0; left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .card:hover .card-img-wrapper img { transform: scale(1.03); }

  .card-actions {
    padding: 0.6rem 0.8rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .card-info h3 {
    font-size: 0.85rem;
    font-weight: 600;
    margin: 0;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .card-info p {
    font-size: 0.7rem;
    color: var(--text-muted);
    margin: 0.1rem 0 0;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .download-group {
    display: flex;
    gap: 0.3rem;
    flex-wrap: wrap;
  }

  .dl-btn {
    padding: 0.2rem 0.5rem;
    border-radius: 9999px;
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.04);
    color: var(--text-muted);
    text-decoration: none;
    font-size: 0.6rem;
    transition: all 0.2s;
    flex: 1;
    text-align: center;
  }

  .dl-btn:hover { background: rgba(255,255,255,0.1); color: #fff; }
  .dl-btn.primary { background: var(--accent-color); color: #fff; border-color: var(--accent-color); }
  .dl-btn.primary:hover { background: var(--accent-hover); }

  .empty-state {
    grid-column: 1 / -1;
    text-align: center;
    padding: 5rem 0;
    background: var(--surface-color);
    border-radius: var(--radius-lg);
    border: 1px dashed var(--surface-border);
    color: var(--text-muted);
  }

  @media (max-width: 1400px) { .gallery { grid-template-columns: repeat(4, 1fr); } }
  @media (max-width: 1024px) { .gallery { grid-template-columns: repeat(3, 1fr); } }
  @media (max-width: 768px) {
    .gallery { grid-template-columns: repeat(2, 1fr); gap: 0.85rem; }
    .header h1 { font-size: 2rem; }
    .stats-pill { flex-direction: column; gap: 0.5rem; text-align: center; border-radius: var(--radius-md); }
    .card-actions { opacity: 1; }
    .card-info h3 { font-size: 0.75rem; }
    .dl-btn { padding: 0.3rem 0.5rem; font-size: 0.6rem; }
  }
  @media (max-width: 480px) { .gallery { grid-template-columns: 1fr; } }
</style>

<script>
  function openModal(el) {
    // 简单弹窗实现
    const img = el.dataset.img;
    const title = el.dataset.title;
    const copyright = el.dataset.copyright;
    const uhd = el.dataset['4k'];
    const mobile = el.dataset.mobile;

    const modal = document.createElement('div');
    modal.style.cssText = `
      position: fixed;
      top: 0; left: 0; width: 100%; height: 100%;
      background: rgba(0,0,0,0.92);
      backdrop-filter: blur(16px);
      z-index: 9999;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 2rem;
      cursor: pointer;
    `;
    modal.onclick = () => modal.remove();

    const inner = document.createElement('div');
    inner.style.cssText = `
      max-width: 90vw; max-height: 85vh;
      background: #111; border-radius: 16px;
      overflow: hidden; cursor: default;
      display: flex; flex-direction: column;
    `;
    inner.onclick = e => e.stopPropagation();

    const imgEl = document.createElement('img');
    imgEl.src = img;
    imgEl.style.cssText = `width: 100%; max-height: 70vh; object-fit: contain;`;

    const info = document.createElement('div');
    info.style.cssText = `padding: 1rem 1.5rem;`;
    info.innerHTML = `
      <h3 style="margin:0;font-size:1.1rem;">${title}</h3>
      <p style="margin:0.2rem 0 0;color:#888;font-size:0.85rem;">${copyright}</p>
      <div style="display:flex;gap:0.5rem;margin-top:0.5rem;flex-wrap:wrap;">
        <a href="${img}" target="_blank" style="padding:0.3rem 1rem;border-radius:9999px;background:#3b82f6;color:#fff;text-decoration:none;font-size:0.8rem;">1080P</a>
        <a href="${uhd}" target="_blank" style="padding:0.3rem 1rem;border-radius:9999px;background:#2563eb;color:#fff;text-decoration:none;font-size:0.8rem;">4K</a>
        <a href="${mobile}" target="_blank" style="padding:0.3rem 1rem;border-radius:9999px;background:rgba(255,255,255,0.1);color:#fff;text-decoration:none;font-size:0.8rem;">手机版</a>
      </div>
    `;

    inner.appendChild(imgEl);
    inner.appendChild(info);
    modal.appendChild(inner);
    document.body.appendChild(modal);
  }
</script>