---
import Base from "@/layouts/Base.astro";
// 壁纸页面不使用数据库，直接使用静态数据
// 数据来源：https://wallpaper.lygalaxy.cn/
// 壁纸 API 文档：https://wallpaper.lygalaxy.cn/static/?file=READRE.md
---

<Base title="必应壁纸库" description="每日同步更新的必应壁纸">
